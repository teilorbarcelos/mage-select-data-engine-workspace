{
  "name": "mage-select-data-engine-workspace",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "node scripts/dev.js",
    "lint": "turbo run lint",
    "test:turbo": "turbo run test",
    "test": "vitest run",
    "validate": "pnpm build && pnpm test",
    "quality-check": "pnpm check-any && pnpm check-comments",
    "check-any": "! grep -rE '(: any|as any|<any>|any\\[\\])' packages apps --exclude-dir=node_modules --exclude-dir=dist",
    "check-comments": "! grep -r '^[[:space:]]*//' packages apps --exclude-dir=node_modules --exclude-dir=dist --exclude='*.md' | grep -v '///'",
    "release": "pnpm build && pnpm -r publish --access public --no-git-checks",
    "prepare": "husky install"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20.0.0",
    "@vitest/coverage-v8": "^2.1.9",
    "happy-dom": "^20.8.9",
    "turbo": "^1.13.0",
    "typescript": "^5.4.0",
    "vitest": "^2.1.9",
    "husky": "^8.0.0"
  }
}
