{
  "name": "mage-select-data-engine-workspace",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "test:turbo": "turbo run test",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "validate": "pnpm build && pnpm test",
    "quality-check": "pnpm check-any && pnpm check-comments",
    "check-any": "! grep -rE '(: any|as any|<any>|any\\[\\])' packages apps --exclude-dir=node_modules --exclude-dir=dist --exclude-dir=__tests__",
    "check-comments": "! grep -r '^[[:space:]]*//' packages apps --exclude-dir=node_modules --exclude-dir=dist --exclude-dir=__tests__ --exclude='*.md' | grep -v '///'",
    "bump": "pnpm --filter \"./packages/*\" exec npm version patch",
    "release": "[ \"$(git rev-parse --abbrev-ref HEAD)\" = \"main\" ] && pnpm build && pnpm --filter \"./packages/*\" publish --access public --no-git-checks || (echo \"Erro: Publicação permitida apenas na branch 'main'.\" && exit 1)",
    "pack:libs": "pnpm --filter \"./packages/*\" pack",
    "prepare": "husky install"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20.0.0",
    "@vitest/coverage-v8": "^2.1.9",
    "happy-dom": "^20.8.9",
    "turbo": "^1.13.0",
    "typescript": "^5.4.0",
    "vitest": "^2.1.9",
    "husky": "^8.0.0"
  }
}