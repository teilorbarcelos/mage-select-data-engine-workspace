{
  "name": "mage-select-data-react-hook-form",
  "version": "1.0.0",
  "description": "React Hook Form integration for mage-select-data-engine. Effortless form synchronization and hydration.",
  "keywords": [
    "react-hook-form",
    "select",
    "form-validation",
    "hydration",
    "mage-select"
  ],
  "author": "Teilor Barcelos",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/teilorbarcelos/mage-select-data-engine"
  },
  "files": [
    "dist"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "import": "./dist/index.mjs"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --clean",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
    "test": "echo \"No tests yet\""
  },
  "peerDependencies": {
    "react": "^18.2.0",
    "react-hook-form": "^7.51.0",
    "mage-select-data-engine": "^1.0.0",
    "mage-select-data-react": "^1.0.0"
  },
  "devDependencies": {
    "react": "^18.2.0",
    "@types/react": "^18.2.0",
    "react-hook-form": "^7.51.0",
    "tsup": "^8.0.2",
    "typescript": "^5.4.0",
    "mage-select-data-engine": "workspace:*",
    "mage-select-data-react": "workspace:*"
  }
}
