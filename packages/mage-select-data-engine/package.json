{
  "name": "mage-select-data-engine",
  "version": "1.0.9",
  "description": "Framework-agnostic data engine for select components featuring offset pagination, dynamic search, and entity hydration.",
  "keywords": [
    "select",
    "search",
    "pagination",
    "hydration",
    "prisma",
    "engine",
    "data-fetching"
  ],
  "author": "Teilor Barcelos",
  "license": "MIT",
  "homepage": "https://github.com/teilorbarcelos/mage-select-data-engine-workspace#readme",
  "bugs": {
    "url": "https://github.com/teilorbarcelos/mage-select-data-engine-workspace/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/teilorbarcelos/mage-select-data-engine-workspace"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "dist",
    "LICENSE"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "import": "./dist/index.mjs"
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "require": "./dist/server.js",
      "import": "./dist/server.mjs"
    }
  },
  "typesVersions": {
    "*": {
      "server": [
        "./dist/server.d.ts"
      ]
    }
  },
  "scripts": {
    "build": "tsup src/index.ts src/server.ts --format cjs,esm --dts --clean",
    "dev": "tsup src/index.ts src/server.ts --format cjs,esm --dts --watch",
    "test": "vitest run"
  },
  "devDependencies": {
    "tsup": "^8.0.2",
    "typescript": "^5.4.0"
  }
}
